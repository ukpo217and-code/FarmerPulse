-- ---------- Fix: authenticated had EXECUTE on app.* functions but no
-- USAGE on the app schema itself. Every RLS policy calling app.*
-- helpers would fail for real logged-in users. Found via live
-- impersonation testing (set role authenticated + request.jwt.claims),
-- not caught by the advisor scan. ----------

grant usage on schema app to authenticated;

-- ---------- Generic coalition partner invitations ----------

create table public.invitations (
  id uuid primary key default gen_random_uuid(),
  email citext not null,
  organization_id uuid not null references public.organizations(id) on delete cascade,
  org_role text not null default 'staff',           -- role within organization_members (e.g. admin, staff)
  platform_role text,                                -- optional: name from public.roles, e.g. 'platform_admin'
  full_name text,                                     -- pre-fill for the actor record
  actor_type public.actor_type not null default 'staff',
  token uuid not null default gen_random_uuid(),
  invited_by uuid references public.actors(id),
  status text not null default 'pending',             -- pending | accepted | expired | revoked
  expires_at timestamptz not null default (now() + interval '14 days'),
  accepted_at timestamptz,
  created_at timestamptz not null default now()
);

create unique index idx_invitations_email_pending on public.invitations (email) where (status = 'pending');
create index idx_invitations_org on public.invitations (organization_id);
create index idx_invitations_token on public.invitations (token);

alter table public.invitations enable row level security;

create policy invitations_access on public.invitations for all to authenticated
using (app.is_platform_admin() or organization_id in (select app.current_org_ids()))
with check (app.is_platform_admin() or organization_id in (select app.current_org_ids()));

-- ---------- Generic signup-bootstrap trigger, replacing the hardcoded one ----------

create or replace function app.bootstrap_from_invitation()
returns trigger
language plpgsql
security definer
set search_path = app, public, pg_temp
as $$
declare
  v_invite public.invitations%rowtype;
  v_actor_id uuid;
  v_platform_role_id uuid;
begin
  select * into v_invite
  from public.invitations
  where lower(email) = lower(new.email)
    and status = 'pending'
    and expires_at > now()
  order by created_at desc
  limit 1;

  if v_invite.id is null then
    -- no matching invitation: leave actor/org linkage for manual/admin setup
    return new;
  end if;

  insert into public.actors (organization_id, actor_type, full_name, email)
  values (v_invite.organization_id, v_invite.actor_type, coalesce(v_invite.full_name, new.email), new.email)
  returning id into v_actor_id;

  update public.users
  set actor_id = v_actor_id
  where auth_user_id = new.id;

  insert into public.organization_members (organization_id, actor_id, role)
  values (v_invite.organization_id, v_actor_id, v_invite.org_role)
  on conflict do nothing;

  if v_invite.platform_role is not null then
    select id into v_platform_role_id from public.roles where name = v_invite.platform_role;
    if v_platform_role_id is not null then
      insert into public.user_roles (user_id, role_id)
      select u.id, v_platform_role_id from public.users u where u.auth_user_id = new.id
      on conflict do nothing;
    end if;
  end if;

  update public.invitations
  set status = 'accepted', accepted_at = now()
  where id = v_invite.id;

  return new;
end;
$$;

-- Remove the hardcoded single-email trigger/function from 0007
drop trigger if exists zzz_bootstrap_cultivate_admin on auth.users;
drop function if exists app.zzz_bootstrap_cultivate_admin();

drop trigger if exists zzz_bootstrap_from_invitation on auth.users;
create trigger zzz_bootstrap_from_invitation
  after insert on auth.users
  for each row
  execute function app.bootstrap_from_invitation();

