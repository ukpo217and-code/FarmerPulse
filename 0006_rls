-- ---------- Core identity ----------

CREATE POLICY org_access ON public.organizations FOR ALL TO authenticated
USING (app.is_platform_admin() OR (id IN (SELECT app.current_org_ids())))
WITH CHECK (app.is_platform_admin() OR (id IN (SELECT app.current_org_ids())));

CREATE POLICY actors_access ON public.actors FOR ALL TO authenticated
USING (app.is_platform_admin() OR (id = app.current_actor_id()) OR (organization_id IN (SELECT app.current_org_ids())))
WITH CHECK (app.is_platform_admin() OR (id = app.current_actor_id()) OR (organization_id IN (SELECT app.current_org_ids())));

CREATE POLICY users_access ON public.users FOR ALL TO authenticated
USING (app.is_platform_admin() OR (auth_user_id = (SELECT auth.uid())) OR (app.actor_org_id(actor_id) IN (SELECT app.current_org_ids())))
WITH CHECK (app.is_platform_admin() OR (auth_user_id = (SELECT auth.uid())) OR (app.actor_org_id(actor_id) IN (SELECT app.current_org_ids())));

CREATE POLICY roles_read ON public.roles FOR SELECT TO authenticated USING (true);
CREATE POLICY roles_admin_write ON public.roles FOR INSERT TO authenticated WITH CHECK (app.is_platform_admin());
CREATE POLICY roles_admin_update ON public.roles FOR UPDATE TO authenticated USING (app.is_platform_admin()) WITH CHECK (app.is_platform_admin());
CREATE POLICY roles_admin_delete ON public.roles FOR DELETE TO authenticated USING (app.is_platform_admin());

CREATE POLICY user_roles_access ON public.user_roles FOR ALL TO authenticated
USING (app.is_platform_admin() OR (user_id IN (SELECT u.id FROM users u WHERE u.auth_user_id = (SELECT auth.uid()))))
