CREATE OR REPLACE FUNCTION app.get_or_create_actor(p_phone text, p_name text DEFAULT 'Unknown Farmer'::text)
 RETURNS uuid
 LANGUAGE plpgsql
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
DECLARE
v_actor UUID;
BEGIN
SELECT id INTO v_actor FROM actors WHERE phone = app.normalize_phone(p_phone) LIMIT 1;
IF v_actor IS NULL THEN
INSERT INTO actors(actor_number, actor_type, full_name, phone)
VALUES(app.generate_actor_number(), 'farmer', p_name, app.normalize_phone(p_phone))
RETURNING id INTO v_actor;
END IF;
RETURN v_actor;
END;
$function$;

