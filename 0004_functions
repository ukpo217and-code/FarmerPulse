-- ---------- Auth bootstrap ----------
-- NOTE: two trigger functions currently coexist on auth.users (handle_new_user
-- and zzz_bootstrap_cultivate_admin). See README for the reconciliation plan
-- before onboarding coalition partners beyond the initial platform_admin.

CREATE OR REPLACE FUNCTION app.handle_new_user()
 RETURNS trigger
 LANGUAGE plpgsql
 SECURITY DEFINER
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
BEGIN
INSERT INTO users (auth_user_id, username, active)
VALUES (NEW.id, NEW.email, TRUE)
ON CONFLICT(auth_user_id) DO NOTHING;
RETURN NEW;
END;
$function$;

CREATE OR REPLACE FUNCTION app.zzz_bootstrap_cultivate_admin()
 RETURNS trigger
 LANGUAGE plpgsql
 SECURITY DEFINER
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
declare
  v_org_id uuid := '6f727364-61e6-465e-8991-e96c9ef0cbfa'; -- Cultivate Integrated Services Ltd
  v_actor_id uuid;
  v_role_id uuid;
begin
  if lower(new.email) = 'ukpoju.andrew@gmail.com' then

    insert into public.actors (organization_id, actor_type, full_name, email, state, lga)
    values (v_org_id, 'staff', 'Ukpoju Andrew', new.email, 'Kogi', 'Lokoja')
    returning id into v_actor_id;

    update public.users
    set actor_id = v_actor_id
    where auth_user_id = new.id;

    insert into public.organization_members (organization_id, actor_id, role)
    values (v_org_id, v_actor_id, 'admin')
    on conflict do nothing;

    select id into v_role_id from public.roles where name = 'platform_admin';

    if v_role_id is not null then
      insert into public.user_roles (user_id, role_id)
      select u.id, v_role_id
      from public.users u
      where u.auth_user_id = new.id
      on conflict do nothing;
    end if;

  end if;

  return new;
end;
$function$;
