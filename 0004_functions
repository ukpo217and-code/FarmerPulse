CREATE OR REPLACE FUNCTION app.database_health()
 RETURNS jsonb
 LANGUAGE plpgsql
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
DECLARE
v_result JSONB;
BEGIN
SELECT jsonb_build_object(
  'actors', (SELECT COUNT(*) FROM actors),
  'farms', (SELECT COUNT(*) FROM farms),
  'organizations', (SELECT COUNT(*) FROM organizations),
  'projects', (SELECT COUNT(*) FROM projects),
  'interventions', (SELECT COUNT(*) FROM interventions),
  'users', (SELECT COUNT(*) FROM users),
  'ai_models', (SELECT COUNT(*) FROM ai_models),
  'weather_stations', (SELECT COUNT(*) FROM weather_stations),
  'whatsapp_sessions', (SELECT COUNT(*) FROM whatsapp_sessions),
  'timestamp', NOW()
) INTO v_result;
INSERT INTO database_health_logs(status, details) VALUES('healthy', v_result);
RETURN v_result;
END;
$function$;

