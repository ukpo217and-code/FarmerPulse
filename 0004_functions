-- ---------- Pulse score / recommendations ----------

CREATE OR REPLACE FUNCTION app.calculate_pulse_score(p_actor uuid)
 RETURNS numeric
 LANGUAGE plpgsql
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
DECLARE
v_area NUMERIC;
v_score NUMERIC;
BEGIN
SELECT app.actor_total_area(p_actor) INTO v_area;
v_score:=LEAST(100,GREATEST(0,v_area*10));
RETURN round(v_score,2);
END;
$function$;

CREATE OR REPLACE FUNCTION app.refresh_pulse_score(p_actor uuid)
 RETURNS void
 LANGUAGE plpgsql
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
BEGIN
INSERT INTO pulse_scores(actor_id, overall_score, calculated_at)
VALUES(p_actor, app.calculate_pulse_score(p_actor), NOW())
ON CONFLICT DO NOTHING;
END;
$function$;

CREATE OR REPLACE FUNCTION app.refresh_actor_score()
 RETURNS trigger
 LANGUAGE plpgsql
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
BEGIN
    PERFORM app.refresh_pulse_score(NEW.actor_id);
    RETURN NEW;
END;
$function$;

CREATE OR REPLACE FUNCTION app.refresh_all_pulse_scores()
 RETURNS integer
 LANGUAGE plpgsql
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
DECLARE
    r RECORD;
    v_count INTEGER := 0;
BEGIN
FOR r IN SELECT id FROM actors LOOP
    PERFORM app.refresh_pulse_score(r.id);
    v_count := v_count + 1;
END LOOP;
RETURN v_count;
END;
$function$;

