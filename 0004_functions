CREATE OR REPLACE FUNCTION app.normalize_phone(phone text)
 RETURNS text
 LANGUAGE plpgsql
 IMMUTABLE
 SET search_path TO 'app', 'public', 'pg_temp'
AS $function$
DECLARE
    p text;
BEGIN
    p := regexp_replace(coalesce(phone,''), '[^0-9]', '', 'g');
    IF length(p) = 11 AND left(p,1) = '0' THEN
        p := '234' || substring(p FROM 2);
    ELSIF length(p) = 10 THEN
        p := '234' || p;
    END IF;
    RETURN p;
END;
$function$;

